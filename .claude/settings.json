{
  "$schema": "https://claude.ai/schemas/claude-settings.json",
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Bash(git *)",
      "Bash(npm test *)",
      "Bash(npm run dev *)",
      "Bash(npm run build *)",
      "Bash(npm run lint *)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx next *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(npm publish *)"
    ]
  }
}
